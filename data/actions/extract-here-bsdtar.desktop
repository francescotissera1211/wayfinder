[Desktop Entry]
Name=Extract Here
TryExec=bsdtar
Exec=sh -c 'archive="$1"; dir="$(dirname "$archive")"; stem="$(basename "$archive")"; case "$stem" in *.tar.gz) stem="${stem%.tar.gz}";; *.tar.xz) stem="${stem%.tar.xz}";; *.tar.zst) stem="${stem%.tar.zst}";; *.tar.bz2) stem="${stem%.tar.bz2}";; *) stem="${stem%.*}";; esac; entries=$(bsdtar tf "$archive" 2>/dev/null | head -2); first=$(echo "$entries" | head -1 | cut -d/ -f1); count=$(echo "$entries" | cut -d/ -f1 | sort -u | wc -l); has_top_dir=$(bsdtar tf "$archive" 2>/dev/null | grep -c "^${first}/$"); if [ "$count" -eq 1 ] && [ -n "$first" ] && [ "$has_top_dir" -ge 1 ]; then cd "$dir" && bsdtar xf "$archive"; else mkdir -p "$dir/$stem" && cd "$dir/$stem" && bsdtar xf "$archive"; fi' _ %f
MimeType=application/zip;application/gzip;application/x-tar;application/x-compressed-tar;application/x-bzip-compressed-tar;application/x-xz-compressed-tar;application/x-zstd-compressed-tar;application/x-7z-compressed;
