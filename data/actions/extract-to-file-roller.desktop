[Desktop Entry]
Name=Extract To...
TryExec=file-roller
Exec=file-roller --extract %F
MimeType=application/zip;application/gzip;application/x-tar;application/x-compressed-tar;application/x-bzip-compressed-tar;application/x-xz-compressed-tar;application/x-zstd-compressed-tar;application/x-7z-compressed;application/x-rar;application/x-rar-compressed;application/vnd.rar;
